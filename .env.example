# Required for content generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model override (defaults to claude-sonnet-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional — email confirmation. Without it, leads are stored but no email is sent.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional — rate limiting via Upstash Redis. Falls back to in-memory if unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
